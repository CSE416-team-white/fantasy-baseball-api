# Server port
PORT=3001

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/app-template

# JWT secret for authentication
JWT_SECRET=change-me-in-production

# Server-side pepper for hashing API keys
API_KEY_PEPPER=change-me-in-production

# Set to true to bypass API key auth (testing only)
DISABLE_API_KEY_AUTH=true

# Optional: archive every pushed notification into the Draft Kit backend.
NOTIFICATION_ARCHIVE_URL=
NOTIFICATION_ARCHIVE_API_KEY=
